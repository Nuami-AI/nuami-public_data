# 공공데이터포털 인증키 (1회 설정, 모든 API 공통)
# 마이페이지 → 개발계정 → 일반인증키(Decoding)
DATA_GO_KR_SERVICE_KEY=your-decoded-service-key

# 체류외국인 API UDDI (1회 설정 — 활용신청 현황에서 uddi: 뒤 UUID만 복사)
# https://www.data.go.kr 활용신청 후 마이페이지에서 확인
IMMIGRATION_API_ENABLED=true
ODCLOUD_MONTHLY_UDDI=a5f8cb94-0844-44cc-bcb8-f363c3b04bf5
ODCLOUD_YEARLY_UDDI=your-yearly-uddi-uuid
ODCLOUD_VISA_UDDI=your-visa-uddi-uuid
ODCLOUD_VISA_YEARLY_UDDI=your-visa-yearly-uddi-uuid

# D-2/D-4 상세 (국적·지역 순위) — 선택, 활용신청 후 UDDI 설정
# https://www.data.go.kr/data/15100020/fileData.do (등록외국인 국적별)
# https://www.data.go.kr/data/15100022/fileData.do (등록외국인 시군구별)
# https://www.data.go.kr/data/15155792/fileData.do (거소신고동포 시군구별 — 장기체류 집계용)
# https://www.data.go.kr/data/15125383/openapi.do (등록+거소 통합 — 대안)
ODCLOUD_NATIONALITY_UDDI=your-nationality-uddi-uuid
ODCLOUD_REGION_UDDI=your-region-uddi-uuid
# 참고 대시보드와 동일한 장기체류(등록+거소) 시군구 순위용 — 활용신청 후 UDDI 설정
ODCLOUD_RESIDENCE_REGION_UDDI=your-residence-region-uddi-uuid
# 또는 통합 API(15125383) 단독 사용 시
# ODCLOUD_LONGTERM_REGION_UDDI=your-longterm-region-uddi-uuid
ODCLOUD_STUDENT_NATIONALITY_UDDI=your-student-nationality-uddi-uuid

# 통계연보 엑셀 폴더 — 기본값 data/yearbook (리포지토리에 포함, Vercel 배포 시 env 생략 가능)
# 필수 파일: *2장_Ⅱ_3*시군구별*국적*등록외국인*.xlsx
#          *2장_Ⅱ_5*시군구별*체류자격별*등록외국인*.xlsx (지역 검색)
#          *2장_Ⅱ_4*시군구별*연령별*등록외국인*.xlsx (지역 상세)
# YEARBOOK_XLSX_DIR=/path/to/custom-yearbook-folder

# 지역 검색 시 D-2/D-4 인원과 지역 소재 대학 연계 표시
# 대학 목록 갱신: npm run build-universities

# 통계청 KOSIS Open API (주민등록인구 — 외국인/내국인 비율)
# https://kosis.kr/openapi/ 에서 인증키 발급
KOSIS_API_KEY=your-kosis-api-key

# 수집 시작 연도 (기본 2000, 변경 불필요)
ODCLOUD_MIN_YEAR=2000

# ── 레거시 (전체 path 형식도 지원) ──
# ODCLOUD_MONTHLY_PATH=15100009/v1/uddi:...

# 세계 이민자 현황: 별도 API 키 불필요 (UN DESA / World Bank Open Data)
